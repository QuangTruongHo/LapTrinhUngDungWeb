@{
    ViewBag.Title = "Đăng ký tài khoản";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-success text-white text-center">
                <h4 class="mb-0">ĐĂNG KÝ THÀNH VIÊN</h4>
            </div>
            <div class="card-body p-4">
                <form action="~/Account/Register" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Họ và tên</label>
                            <input type="text" name="customerName" class="form-control" placeholder="Nguyễn Văn A" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Điện thoại</label>
                            <input type="tel" name="phone" class="form-control" placeholder="0905..." required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email (Dùng để đăng nhập)</label>
                        <input type="email" name="email" class="form-control" placeholder="example@gmail.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ</label>
                        <input type="text" name="address" class="form-control" placeholder="Số nhà, tên đường..." required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Mật khẩu</label>
                            <input type="password" name="password" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                            <input type="password" name="confirmPassword" class="form-control" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100 btn-lg">TẠO TÀI KHOẢN</button>
                </form>
            </div>
        </div>
    </div>
</div>