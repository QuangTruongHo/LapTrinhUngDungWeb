@model IEnumerable<SV22T1020488.Shop.Models.CartItem>
@{
    ViewBag.Title = "Giỏ hàng của bạn";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-cart-check text-primary"></i> Giỏ hàng</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle bg-white mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "no-image.jpg" : item.Photo)"
                                         style="width: 60px; height: 60px; object-fit: contain;" class="me-3 rounded border">
                                    <div>
                                        <div class="fw-bold">@item.ProductName</div>
                                        <small class="text-muted">ĐVT: @item.Unit</small>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center" style="width: 150px;">
                                <span class="badge bg-secondary px-3 py-2">@item.Quantity</span>
                            </td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end fw-bold text-primary">@item.TotalPrice.ToString("N0")</td>
                            <td class="text-center">
                                <a href="~/Cart/Remove/@item.ProductID" class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Xóa sản phẩm này?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="3" class="text-end fw-bold fs-5">Tổng cộng:</td>
                        <td class="text-end fw-bold fs-5 text-danger">@Model.Sum(x => x.TotalPrice).ToString("N0") VNĐ</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
        <div class="mt-4 d-flex justify-content-between">
            <a href="~/Product" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Tiếp tục mua sắm</a>
            <a href="~/Order/Checkout" class="btn btn-success btn-lg px-5 shadow">THANH TOÁN <i class="bi bi-credit-card ms-2"></i></a>
        </div>
    }
    else
    {
        <div class="text-center py-5 shadow-sm bg-white rounded">
            <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
            <p class="fs-4 text-muted mt-3">Giỏ hàng của bạn đang trống.</p>
            <a href="~/Product" class="btn btn-primary px-4">Mua sắm ngay</a>
        </div>
    }
</div>