@model IEnumerable<SV22T1020488.Shop.Models.CartItem>
@{
    ViewBag.Title = "GIỎ HÀNG CỦA BẠN";
}

<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
@* Thêm SweetAlert2 CDN *@
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --neo-border: #1a1a1a;
        --neo-shadow: #000000;
        --neo-yellow: #f4d03f;
        --neo-pink: #ffafcc;
        --neo-blue: #8ecae6;
        --neo-cyan: #219ebc;
        --neo-bg: #e0f2fe;
        --neo-danger: #ff595e;
    }

    body {
        background-color: #8ecae6;
        background-image: linear-gradient(135deg, #8ecae6 0%, #ffafcc 100%);
        font-family: 'Space Mono', monospace;
        color: var(--neo-border);
        min-height: 100vh;
    }

    /* --- FORM NHỎ LẠI --- */
    .cart-container {
        background: white;
        border: 6px solid var(--neo-border);
        box-shadow: 12px 12px 0px var(--neo-shadow);
        padding: 25px; /* Giảm padding */
        margin: 30px auto;
        max-width: 900px; /* Giới hạn chiều rộng form */
    }

    /* --- HEADER MỚI --- */
    .cart-header-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 6px solid var(--neo-border);
        padding-bottom: 15px;
        margin-bottom: 25px;
    }

    .cart-title {
        font-weight: 900;
        text-transform: uppercase;
        font-size: 1.8rem; /* Thu nhỏ chữ */
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .neo-table {
        border-collapse: separate;
        border-spacing: 0;
        width: 100%;
        border: 3px solid var(--neo-border);
        font-size: 0.85rem; /* Thu nhỏ bảng */
    }

        .neo-table thead {
            background: var(--neo-yellow);
        }

        .neo-table th {
            border-bottom: 3px solid var(--neo-border);
            border-right: 2px solid var(--neo-border);
            padding: 10px;
            text-transform: uppercase;
            font-weight: 900;
        }

        .neo-table td {
            padding: 10px;
            border-bottom: 2px solid var(--neo-border);
            border-right: 2px solid var(--neo-border);
            background: #fff;
            font-weight: 700;
        }

    .qty-control {
        display: flex;
        border: 2px solid var(--neo-border);
        width: fit-content;
        margin: 0 auto;
        box-shadow: 2px 2px 0px var(--neo-border);
    }

    .qty-btn {
        width: 25px;
        height: 25px;
        background: #eee;
        border: none;
        font-weight: 900;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .qty-input {
        width: 35px;
        border: none;
        border-left: 2px solid var(--neo-border);
        border-right: 2px solid var(--neo-border);
        text-align: center;
        font-weight: 900;
        outline: none;
        font-size: 0.8rem;
    }

    .btn-neo-action {
        border: 3px solid var(--neo-border);
        font-weight: 900;
        text-transform: uppercase;
        padding: 8px 16px;
        box-shadow: 4px 4px 0px var(--neo-border);
        transition: 0.1s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        color: var(--neo-border);
        font-size: 0.85rem;
        cursor: pointer;
    }

        .btn-neo-action:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--neo-border);
            color: var(--neo-border);
        }

    .btn-neo-delete {
        background: var(--neo-danger);
        color: white !important;
    }

    .btn-neo-back {
        background: var(--neo-blue);
    }

    .btn-neo-clear {
        background: #ff595e;
        color: white;
    }

    .btn-neo-checkout {
        background: var(--neo-yellow);
        font-size: 1rem;
        padding: 12px 25px;
    }

    .total-row {
        background: var(--neo-pink) !important;
        font-size: 1.2rem;
    }

    /* Custom SweetAlert Neo-Brutalism */
    .neo-swal-popup {
        border: 5px solid var(--neo-border) !important;
        border-radius: 0 !important;
        box-shadow: 10px 10px 0px var(--neo-shadow) !important;
        font-family: 'Space Mono', monospace !important;
    }

    .neo-swal-button {
        border: 3px solid var(--neo-border) !important;
        border-radius: 0 !important;
        box-shadow: 4px 4px 0px var(--neo-shadow) !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
    }
</style>

<div class="container">
    <div class="cart-container">
        @* --- HEADER: NÚT QUAY LẠI BÊN TRÁI, TIÊU ĐỀ BÊN PHẢI --- *@
        <div class="cart-header-wrapper">
            <a href="javascript:void(0)" onclick="goBackWithPosition()" class="btn-neo-action btn-neo-back">
                <i class="bi bi-arrow-left me-2"></i> QUAY LẠI
            </a>
            <h2 class="cart-title">
                @ViewBag.Title <i class="bi bi-cart-check-fill ms-2"></i>
            </h2>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="neo-table">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center" style="width: 120px;">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                            <th class="text-center">Xóa</th>
                        </tr>
                    </thead>
                    <tbody id="cart-body">
                        @foreach (var item in Model)
                        {
                            <tr class="cart-item" data-id="@item.ProductID">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@Url.Content("~/images/products/" + (string.IsNullOrEmpty(item.Photo) ? "no-image.jpg" : item.Photo))"
                                             class="me-2" style="width: 40px; height: 40px; object-fit: contain; border: 1px solid #ddd">
                                        <div class="fw-bold text-uppercase" style="font-size: 0.8rem; line-height: 1.2;">@item.ProductName</div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="qty-control">
                                        <button class="qty-btn" onclick="updateQty(this, -1)">-</button>
                                        <input type="text" class="qty-input" value="@item.Quantity" readonly>
                                        <button class="qty-btn" onclick="updateQty(this, 1)">+</button>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <span class="item-price" data-price="@item.SalePrice">@item.SalePrice.ToString("N0")</span>
                                </td>
                                <td class="text-end text-primary">
                                    <span class="item-total">@item.TotalPrice.ToString("N0")</span>
                                </td>
                                <td class="text-center">
                                    <a href="javascript:void(0)"
                                       onclick="confirmRemoveItem('@Url.Action("Remove", "Cart", new { id = item.ProductID })')"
                                       class="btn-neo-action btn-neo-delete p-1 px-2">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="total-row">
                            <td colspan="3" class="text-end fw-black">TỔNG CỘNG:</td>
                            <td class="text-end fw-black">
                                <span id="cart-grand-total">@Model.Sum(x => x.TotalPrice).ToString("N0")</span> VNĐ
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <a href="javascript:void(0)" class="btn-neo-action btn-neo-clear" onclick="confirmClearCart()">
                    <i class="bi bi-trash"></i> LÀM TRỐNG GIỎ
                </a>
                <a href="@Url.Action("Checkout", "Order")" class="btn-neo-action btn-neo-checkout">
                    ĐẶT HÀNG <i class="bi bi-arrow-right-circle-fill ms-2"></i>
                </a>
            </div>
        }
        else
        {
            <div class="empty-cart-box text-center py-5">
                <h3 class="text-uppercase fw-black">Giỏ hàng trống!</h3>
                <a href="@Url.Action("Index", "Home")" class="btn-neo-action btn-neo-checkout mt-3">ĐI MUA SẮM</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Hàm quay lại và giữ vị trí cuộn trang cũ
        function goBackWithPosition() {
            if (document.referrer.indexOf(window.location.host) !== -1) {
                window.history.back();
            } else {
                window.location.href = '@Url.Action("Index", "Home")';
            }
        }

        // Hàm xác nhận làm trống giỏ hàng bằng SweetAlert2
        function confirmClearCart() {
            Swal.fire({
                title: 'DỌN SẠCH GIỎ HÀNG?',
                text: "Tất cả sản phẩm sẽ bị xóa khỏi giỏ!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff595e',
                cancelButtonColor: '#1a1a1a',
                confirmButtonText: 'ĐỒNG Ý, XÓA HẾT!',
                cancelButtonText: 'HỦY',
                customClass: {
                    popup: 'neo-swal-popup',
                    confirmButton: 'btn-neo-action btn-neo-clear neo-swal-button',
                    cancelButton: 'btn-neo-action btn-neo-back neo-swal-button'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Clear", "Cart")';
                }
            });
        }

        // Hàm xác nhận xóa từng sản phẩm bằng SweetAlert2
        function confirmRemoveItem(url) {
            Swal.fire({
                title: 'XÓA SẢN PHẨM NÀY?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#ff595e',
                cancelButtonColor: '#1a1a1a',
                confirmButtonText: 'XÓA LUÔN!',
                cancelButtonText: 'KHÔNG',
                customClass: {
                    popup: 'neo-swal-popup',
                    confirmButton: 'btn-neo-action btn-neo-clear neo-swal-button',
                    cancelButton: 'btn-neo-action btn-neo-back neo-swal-button'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        }

        function updateQty(btn, change) {
            const row = btn.closest('.cart-item');
            const input = row.querySelector('.qty-input');
            const price = parseFloat(row.querySelector('.item-price').getAttribute('data-price'));
            const itemTotalSpan = row.querySelector('.item-total');

            let currentQty = parseInt(input.value);
            let newQty = currentQty + change;

            if (newQty >= 1) {
                input.value = newQty;
                let newTotal = newQty * price;
                itemTotalSpan.innerText = newTotal.toLocaleString('en-US');
                calculateGrandTotal();

                const id = row.getAttribute('data-id');
                updateCartSession(id, newQty);
            }
        }

        function calculateGrandTotal() {
            let grandTotal = 0;
            document.querySelectorAll('.item-total').forEach(span => {
                let val = parseFloat(span.innerText.replace(/,/g, ''));
                if (!isNaN(val)) grandTotal += val;
            });
            document.getElementById('cart-grand-total').innerText = grandTotal.toLocaleString('en-US');
        }

        function updateCartSession(id, qty) {
            $.post("@Url.Action("UpdateQuantity", "Cart")", { id: id, quantity: qty }, function(response) {
                if(!response.success) {
                    alert(response.message || "Không thể cập nhật số lượng");
                }
            }).fail(function() {
                console.error("Lỗi kết nối server");
            });
        }
    </script>
}