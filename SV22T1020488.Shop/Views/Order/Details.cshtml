@using SV22T1020488.Models.Sales
@using SV22T1020488.Shop.AppCodes @* Đảm bảo namespace này khớp với file SelectListHelper của bạn *@
@model IEnumerable<OrderDetailViewInfo>
@{
    var order = ViewBag.Order as Order;
    ViewBag.Title = "Chi tiết đơn hàng #" + order?.OrderID;

    // Lấy danh sách Tỉnh/Thành từ Helper (hàm async nên dùng await)
    var provinces = await SelectListHelper.Provinces();

    // Kiểm tra trạng thái hủy
    bool isCancelled = order.Status == OrderStatusEnum.Cancelled || order.Status == OrderStatusEnum.Rejected;

    // Logic kiểm tra quyền chỉnh sửa địa chỉ (Chỉ khi đơn mới tạo)
    bool canEdit = order.Status == OrderStatusEnum.New;

    // Logic kiểm tra xem khách có được quyền hủy không (Chỉ khi đơn mới tạo)
    bool canCancel = order.Status == OrderStatusEnum.New;

    // Thiết lập màu sắc chủ đạo dựa trên trạng thái
    string statusBgColor = isCancelled ? "#fee2e2" : "#fdf2f8";
    string statusLabelBg = isCancelled ? "#ef4444" : "var(--neo-yellow)";
    string statusLabelText = isCancelled ? "#fff" : "#000";
}

<style>
    .neo-compact-final {
        font-size: 0.92rem;
    }

    .info-box-neo {
        background: #ffffff;
        border: 2px solid #000;
        padding: 10px;
        margin-bottom: 10px;
        box-shadow: 3px 3px 0px #000;
        position: relative;
    }

    .info-label-neo {
        font-size: 0.7rem;
        font-weight: 900;
        text-transform: uppercase;
        color: #666;
        margin-bottom: 2px;
        display: block;
    }

    .info-value-neo {
        font-weight: 800;
        color: #000;
        margin-bottom: 0;
        line-height: 1.2;
    }

    .navigation-wrapper-neo {
        background: #f3f4f6;
        border: 2px solid #000;
        padding: 15px;
        margin-top: 20px;
        box-shadow: 6px 6px 0px #000;
    }

    .btn-neo-nav {
        display: inline-block;
        padding: 8px 20px;
        font-size: 0.85rem;
        font-weight: 900;
        text-transform: uppercase;
        text-decoration: none;
        border: 2px solid #000;
        color: #000;
        transition: all 0.2s;
        box-shadow: 3px 3px 0px #000;
        cursor: pointer;
    }

        .btn-neo-nav:hover {
            transform: translate(-1px, -1px);
            box-shadow: 5px 5px 0px #000;
            color: #000;
        }

    .btn-neo-nav-primary {
        background: var(--neo-yellow);
    }

    .btn-neo-nav-secondary {
        background: #fff;
    }

    .btn-neo-cancel {
        background: #ff4d4d;
        color: #fff !important;
        width: 100%;
        margin-top: 10px;
        text-align: center;
    }

    /* Nút sửa địa chỉ nhỏ gọn */
    .btn-edit-addr {
        position: absolute;
        right: 8px;
        top: 8px;
        background: #a5f3fc;
        border: 1px solid #000;
        padding: 2px 6px;
        font-size: 0.6rem;
        font-weight: 900;
        box-shadow: 2px 2px 0px #000;
        cursor: pointer;
    }

    .fw-black {
        font-weight: 900;
    }

    .table > :not(caption) > * > * {
        padding: 0.6rem 0.4rem;
    }

    .cancelled-shake {
        animation: subtle-shake 0.5s ease-in-out;
    }
    @Html.Raw("@") keyframes subtle-shake {
        0%, 100%

    {
        transform: translateX(0);
    }

    25% {
        transform: translateX(-2px);
    }

    75% {
        transform: translateX(2px);
    }

    }

    /* Modal Style */
    .neo-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(2px);
    }

    .neo-modal-content {
        position: relative;
        background: #fff;
        margin: 10% auto;
        padding: 25px;
        border: 4px solid #000;
        width: 90%;
        max-width: 450px;
        box-shadow: 10px 10px 0px #000;
    }

    .neo-input {
        width: 100%;
        border: 2px solid #000;
        padding: 8px;
        font-weight: 700;
        margin-bottom: 15px;
        box-shadow: 3px 3px 0px #ccc;
        background: #fff; /* Đảm bảo select có nền trắng */
    }

        .neo-input:focus {
            outline: none;
            box-shadow: 3px 3px 0px var(--neo-yellow);
        }
</style>

<div class="container-fluid neo-compact-final py-3" style="max-width: 1150px;">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        @* Cột 1: Theo dõi đơn hàng *@
        <div class="col-lg-4">
            <div class="custom-card p-3 h-100 @(isCancelled ? "cancelled-shake" : "")"
                 style="background: @statusBgColor; border: 2px solid #000; box-shadow: 6px 6px 0px #000;">

                <h6 class="fw-bold text-uppercase border-bottom border-dark border-2 pb-2 mb-3">
                    <i class="bi bi-geo-alt-fill me-1"></i>Theo dõi đơn
                </h6>

                <div class="mb-3 text-center">
                    <div class="fw-black text-uppercase p-2"
                         style="background: @statusLabelBg; color: @statusLabelText; border: 2px solid #000; box-shadow: 4px 4px 0px #000; font-size: 1.1rem;">
                        @order.Status.GetDescription()
                    </div>
                </div>

                <div class="info-box-neo">
                    <span class="info-label-neo">Mã đơn</span>
                    <p class="info-value-neo">#@order.OrderID</p>
                </div>

                <div class="info-box-neo">
                    <span class="info-label-neo">Ngày đặt</span>
                    <p class="info-value-neo">@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                </div>

                <div class="info-box-neo">
                    <span class="info-label-neo">Địa chỉ giao hàng</span>
                    @if (canEdit)
                    {
                        <button class="btn-edit-addr" onclick="openAddressModal()">SỬA ĐỊA CHỈ</button>
                    }
                    <p class="info-value-neo" id="currentAddress" style="font-size: 0.85rem;">@order.DeliveryAddress</p>
                    <p class="info-value-neo text-muted small" id="currentProvince">@order.DeliveryProvince</p>
                </div>

                @if (canCancel)
                {
                    <button type="button" class="btn-neo-nav btn-neo-cancel" onclick="handleCancelOrder(@order.OrderID)">
                        <i class="bi bi-x-circle-fill me-1"></i> Hủy đơn hàng này
                    </button>
                }

                @if (isCancelled)
                {
                    <div class="p-2 mt-2 text-center fw-bold" style="border: 2px solid #000; background: #fff; color: #ef4444; font-size: 0.8rem; text-transform: uppercase;">
                        <i class="bi bi-exclamation-octagon-fill me-1"></i>Đơn hàng này không khả dụng
                    </div>
                }
            </div>
        </div>

        @* Cột 2: Danh sách sản phẩm *@
        <div class="col-lg-8">
            <div class="custom-card p-3" style="background: #fff; border: 2px solid #000; box-shadow: 6px 6px 0px #000;">
                <h6 class="fw-bold text-uppercase border-bottom border-dark border-2 pb-2 mb-3">
                    <i class="bi bi-bag-check-fill me-1"></i>Sản phẩm
                </h6>

                <div class="table-responsive">
                    <table class="table align-middle m-0" style="font-size: 0.9rem;">
                        <thead>
                            <tr class="fw-black text-uppercase small" style="border-bottom: 2px solid #000;">
                                <th class="ps-0">Mặt hàng</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Tổng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr style="border-bottom: 1px solid #eee;">
                                    <td class="ps-0 py-2">
                                        <div class="d-flex align-items-center">
                                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "no-image.png" : item.Photo)"
                                                 style="width: 48px; height: 48px; border: 2px solid #000; object-fit: cover; opacity: @(isCancelled ? "0.6" : "1");" class="me-2">
                                            <div style="line-height: 1.1;">
                                                <div class="fw-bold text-truncate @(isCancelled ? "text-decoration-line-through text-muted" : "")" style="max-width: 250px;">@item.ProductName</div>
                                                <small class="text-muted" style="font-size: 0.7rem;">@item.Unit</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center fw-bold">@item.Quantity</td>
                                    <td class="text-end">@item.SalePrice.ToString("N0")</td>
                                    <td class="text-end fw-black">@item.TotalPrice.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-black pt-3">TỔNG CỘNG:</td>
                                <td class="text-end pt-3">
                                    <span class="h5 fw-black @(isCancelled ? "text-muted" : "text-danger")">
                                        @Model.Sum(x => x.TotalPrice).ToString("N0")đ
                                    </span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="navigation-wrapper-neo d-flex justify-content-between align-items-center">
                <a href="~/Order/History" class="btn-neo-nav btn-neo-nav-secondary">
                    <i class="bi bi-arrow-left"></i> Lịch sử
                </a>
                <a href="~/Home" class="btn-neo-nav btn-neo-nav-primary">
                    Mua tiếp <i class="bi bi-cart-plus"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@* MODAL HỦY ĐƠN *@
<div id="cancelModal" class="neo-modal">
    <div class="neo-modal-content">
        <h5 class="fw-black text-uppercase mb-3">Xác nhận hủy đơn</h5>
        <p class="fw-bold">Bạn có chắc chắn muốn hủy đơn hàng <span id="displayOrderId" class="text-danger"></span> không?</p>
        <div class="d-flex gap-2 mt-4">
            <button onclick="closeCancelModal()" class="btn-neo-nav btn-neo-nav-secondary" style="flex: 1;">Quay lại</button>
            <button id="btnConfirmCancel" class="btn-neo-nav btn-neo-cancel" style="flex: 1; margin-top:0;">Đồng ý hủy</button>
        </div>
    </div>
</div>

@* MODAL SỬA ĐỊA CHỈ - ĐÃ CẬP NHẬT SELECT *@
<div id="addressModal" class="neo-modal">
    <div class="neo-modal-content">
        <h5 class="fw-black text-uppercase mb-3">Cập nhật địa chỉ nhận hàng</h5>
        <label class="info-label-neo">Địa chỉ chi tiết</label>
        <input type="text" id="inputAddress" class="neo-input" value="@order.DeliveryAddress" placeholder="Số nhà, tên đường...">

        <label class="info-label-neo">Tỉnh / Thành phố</label>
        <select id="selectProvince" class="neo-input">
            @foreach (var item in provinces)
            {
                if (item.Value == order.DeliveryProvince)
                {
                    <option value="@item.Value" selected>@item.Text</option>
                }
                else
                {
                    <option value="@item.Value">@item.Text</option>
                }
            }
        </select>

        <div class="d-flex gap-2 mt-2">
            <button onclick="closeAddressModal()" class="btn-neo-nav btn-neo-nav-secondary" style="flex: 1;">Hủy bỏ</button>
            <button id="btnConfirmAddress" class="btn-neo-nav btn-neo-nav-primary" style="flex: 1;">Lưu thay đổi</button>
        </div>
    </div>
</div>

<script>
    // --- PHẦN HỦY ĐƠN ---
    let selectedOrderIdForCancel = 0;

    function handleCancelOrder(orderId) {
        selectedOrderIdForCancel = orderId;
        document.getElementById('displayOrderId').innerText = '#' + orderId;
        document.getElementById('cancelModal').style.display = 'block';
    }

    function closeCancelModal() {
        document.getElementById('cancelModal').style.display = 'none';
    }

    document.getElementById('btnConfirmCancel').addEventListener('click', function() {
        const btn = this;
        const token = $('input[name="__RequestVerificationToken"]').val();
        btn.disabled = true;

        $.ajax({
            url: '/Order/Cancel/' + selectedOrderIdForCancel,
            type: 'POST',
            data: { "__RequestVerificationToken": token },
            success: function (res) {
                if (res.code == 1) location.reload();
                else { alert(res.message); btn.disabled = false; }
            },
            error: function () { alert("Lỗi hệ thống!"); btn.disabled = false; }
        });
    });

    // --- PHẦN CẬP NHẬT ĐỊA CHỈ ---
    function openAddressModal() {
        document.getElementById('addressModal').style.display = 'block';
    }

    function closeAddressModal() {
        document.getElementById('addressModal').style.display = 'none';
    }

    document.getElementById('btnConfirmAddress').addEventListener('click', function() {
        const btn = this;
        const addr = $('#inputAddress').val();
        const prov = $('#selectProvince').val(); @* Lấy giá trị từ select *@
        const token = $('input[name="__RequestVerificationToken"]').val();

        if(!addr || !prov) { alert("Vui lòng nhập đầy đủ thông tin!"); return; }

        btn.innerHTML = 'Đang lưu...';
        btn.disabled = true;

        $.ajax({
            url: '/Order/UpdateAddress',
            type: 'POST',
            data: {
                orderId: @order.OrderID,
                deliveryAddress: addr,
                deliveryProvince: prov,
                "__RequestVerificationToken": token
            },
            success: function (res) {
                if (res.code == 1) {
                    location.reload();
                } else {
                    alert(res.message);
                    btn.innerHTML = 'Lưu thay đổi';
                    btn.disabled = false;
                }
            },
            error: function() {
                alert("Lỗi kết nối máy chủ!");
                btn.disabled = false;
            }
        });
    });

    // Close modals on outside click
    window.onclick = function(event) {
        if (event.target.className === 'neo-modal') {
            closeCancelModal();
            closeAddressModal();
        }
    }
</script>