@using SV22T1020488.Shop.AppCodes
@using SV22T1020488.BusinessLayers
@using SV22T1020488.Shop.Models
@model SV22T1020488.Models.Partner.Customer
@{
    ViewBag.Title = "Xác nhận đặt hàng";

    // --- LOGIC LẤY GIỎ HÀNG ---
    bool isBuyNow = ViewBag.IsBuyNow ?? false;
    List<CartItem> cart;
    if (isBuyNow)
    {
        cart = SV22T1020488.Shop.ApplicationContext.GetSessionData<List<CartItem>>("BUY_NOW_TEMP") ?? new List<CartItem>();
    }
    else
    {
        cart = SV22T1020488.Shop.CartHelper.GetCart(Context);
    }

    decimal total = cart.Sum(x => x.TotalPrice);
}

<style>
    :root {
        --neo-green: #2ecc71;
        --neo-blue: #8ecae6;
        --neo-yellow: #f4d03f;
        --neo-red: #ff5e5e;
    }

    .checkout-container {
        margin-top: 50px;
        margin-bottom: 50px;
    }

    .neo-card {
        background: #fff;
        border: 4px solid #000;
        box-shadow: 12px 12px 0px #000;
        padding: 30px;
        height: 100%;
    }

    .neo-input {
        border: 3px solid #000 !important;
        border-radius: 0 !important;
        padding: 12px !important;
        font-weight: 700 !important;
        box-shadow: 4px 4px 0px #000;
        margin-bottom: 20px;
    }

    .btn-confirm-order {
        background: var(--neo-green);
        color: #000;
        border: 4px solid #000;
        border-radius: 0;
        font-weight: 900;
        text-transform: uppercase;
        padding: 15px;
        box-shadow: 6px 6px 0px #000;
        transition: 0.1s;
        width: 100%;
    }

        .btn-confirm-order:hover:not(:disabled) {
            transform: translate(3px, 3px);
            box-shadow: 0px 0px 0px #000;
        }

        .btn-confirm-order:disabled {
            background: #ccc;
            cursor: not-allowed;
            box-shadow: none;
        }

    .checkout-item-list {
        max-height: 350px;
        overflow-y: auto;
        margin-bottom: 20px;
        border: 3px solid #000;
        padding: 10px;
        background: #fff;
    }

    .checkout-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 10px 0;
        border-bottom: 2px dashed #000;
    }

    .item-img {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border: 2px solid #000;
    }

    /* CSS MỚI CHO BỘ TĂNG GIẢM SỐ LƯỢNG */
    .neo-qty-box {
        display: flex;
        border: 2px solid #000;
        width: fit-content;
        margin-top: 5px;
    }

    .qty-btn {
        background: #fff;
        border: none;
        width: 25px;
        height: 25px;
        font-weight: 900;
        cursor: pointer;
    }

        .qty-btn:hover {
            background: var(--neo-yellow);
        }

    .qty-input {
        width: 35px;
        border-left: 2px solid #000;
        border-right: 2px solid #000;
        text-align: center;
        font-weight: 800;
        font-size: 0.8rem;
    }

    .payment-option {
        border: 3px solid #000;
        padding: 15px;
        margin-bottom: 15px;
        background: #f8f9fa;
        cursor: pointer;
    }

    .error-msg {
        color: var(--neo-red);
        font-size: 0.85rem;
        font-weight: 800;
        margin-top: 5px;
        display: none;
    }

    .summary-item {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-weight: 700;
    }
</style>

<div class="container checkout-container">
    <div class="row g-5">
        @* CỘT TRÁI: THÔNG TIN GIAO HÀNG *@
        <div class="col-md-6">
            <div class="neo-card" style="background: var(--neo-blue);">
                <h2 class="fw-black text-uppercase mb-4 border-bottom border-dark border-4 pb-2">🚚 Giao hàng</h2>

                <form action="~/Order/Checkout" method="post" id="formCheckout">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="isBuyNow" value="@(isBuyNow ? "true" : "false")" />

                    <h6 class="fw-bold text-uppercase mb-2">Địa chỉ nhận hàng:</h6>
                    <div class="mb-3">
                        <label class="small fw-bold">Tỉnh/Thành phố:</label>
                        <select name="deliveryProvince" class="form-select neo-input" required>
                            <option value=""></option>
                            @foreach (var item in await SelectListHelper.Provinces())
                            {
                                <option value="@item.Value" selected="@(item.Value == Model?.Province ? "selected" : null)">@item.Text</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold">Địa chỉ chi tiết:</label>
                        <textarea name="deliveryAddress" class="form-control neo-input" rows="3"
                                  placeholder="Số nhà, tên đường, phường/xã..." required>@Model?.Address</textarea>
                    </div>

                    <h6 class="fw-bold text-uppercase mb-2 mt-4">Phương thức thanh toán:</h6>
                    <div class="payment-option">
                        <div class="form-check">
                            <input class="form-check-input border-dark" type="radio" name="paymentMethod" id="cod" value="COD" checked>
                            <label class="form-check-label fw-bold cursor-pointer" for="cod">
                                💵 Tiền mặt khi nhận hàng (COD)
                            </label>
                        </div>
                    </div>

                    <div class="payment-option bg-light" id="opt-bank">
                        <div class="form-check">
                            <input class="form-check-input border-dark" type="radio" name="paymentMethod" id="bank" value="BANK">
                            <label class="form-check-label fw-bold cursor-pointer" for="bank">
                                🏦 Chuyển khoản ngân hàng
                            </label>
                        </div>
                        <div class="error-msg" id="msg-bank">⚠️ Hiện tại chưa hỗ trợ phương thức này!</div>
                    </div>

                    <div class="payment-option bg-light" id="opt-momo">
                        <div class="form-check">
                            <input class="form-check-input border-dark" type="radio" name="paymentMethod" id="momo" value="MOMO">
                            <label class="form-check-label fw-bold cursor-pointer" for="momo">
                                📱 Ví điện tử (Momo/ZaloPay)
                            </label>
                        </div>
                        <div class="error-msg" id="msg-momo">⚠️ Hiện tại chưa hỗ trợ phương thức này!</div>
                    </div>

                    <button type="submit" class="btn-confirm-order mt-3" id="btnSubmit">
                        <i class="bi bi-bag-check-fill me-2"></i> XÁC NHẬN ĐẶT MUA
                    </button>
                </form>
            </div>
        </div>

        @* CỘT PHẢI: CHI TIẾT ĐƠN HÀNG (ĐÃ CẬP NHẬT LOGIC CHỈNH SỐ LƯỢNG) *@
        <div class="col-md-6">
            <div class="neo-card" style="background: var(--neo-yellow);">
                <h2 class="fw-black text-uppercase mb-4 border-bottom border-dark border-4 pb-2">🛒 Đơn hàng</h2>

                <div class="checkout-item-list shadow-sm">
                    @foreach (var item in cart)
                    {
                        <div class="checkout-item" data-product-id="@item.ProductID" data-price="@item.SalePrice">
                            <img src="https://localhost:7089/images/products/@(string.IsNullOrEmpty(item.Photo) ? "no-image.jpg" : item.Photo)" class="item-img" />
                            <div class="flex-grow-1">
                                <div class="fw-bold text-uppercase small">@item.ProductName</div>
                                <div class="small text-muted">Đơn giá: @item.SalePrice.ToString("N0")</div>

                                @* BỘ ĐIỀU CHỈNH SỐ LƯỢNG MỚI *@
                                <div class="neo-qty-box">
                                    <button class="qty-btn btn-minus-qty">-</button>
                                    <input type="text" class="qty-input" value="@item.Quantity" readonly />
                                    <button class="qty-btn btn-plus-qty">+</button>
                                </div>
                            </div>
                            <div class="fw-bold text-end">
                                <span class="item-total-price">@item.TotalPrice.ToString("N0")</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="summary-list mt-4">
                    <div class="summary-item">
                        <span>Số lượng mặt hàng:</span>
                        <span id="summary-count">@cart.Count</span>
                    </div>
                    <div class="summary-item">
                        <span>Phí vận chuyển:</span>
                        <span class="text-success fw-bold">MIỄN PHÍ</span>
                    </div>
                    <hr class="border-dark border-2" />
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="h4 fw-black text-uppercase">Tổng cộng:</span>
                        <span class="h3 fw-black text-danger"><span id="grand-total">@total.ToString("N0")</span> VNĐ</span>
                    </div>
                </div>

                <div class="mt-4 p-3 bg-white border border-dark border-2">
                    <p class="small mb-0 fw-bold"><i class="bi bi-info-circle-fill"></i> Lưu ý:</p>
                    <p class="small mb-0">Chúng tôi sẽ liên hệ xác nhận trong vòng 10 phút sau khi bạn đặt hàng.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {
        // --- LOGIC CẬP NHẬT SỐ LƯỢNG AJAX ---
        function updateCartQuantity(productId, newQuantity, $itemRow) {
            // Lấy giá trị từ input hidden đã có trong form
            const isBuyNow = $("input[name='isBuyNow']").val() === "true";

            // LUÔN GỌI VỀ UpdateQuantity, không gọi hàm 404 kia nữa
            const url = "/Cart/UpdateQuantity";

            $.ajax({
                url: url,
                type: "POST",
                data: {
                    id: productId,
                    quantity: newQuantity,
                    isBuyNow: isBuyNow // Gửi thêm tham số này cho Controller
                },
                success: function (res) {
                    if (res.success) {
                        // Cập nhật số lượng trong ô input
                        $itemRow.find('.qty-input').val(newQuantity);

                        // Cập nhật thành tiền của dòng đó từ Server trả về
                        $itemRow.find('.item-total-price').text(res.itemTotal);

                        // Cập nhật tổng cộng đơn hàng từ Server trả về (chính xác tuyệt đối)
                        $('#grand-total').text(res.grandTotal);
                    } else {
                        alert(res.message || "Không thể cập nhật số lượng");
                    }
                },
                error: function () {
                    alert("Lỗi kết nối máy chủ. Hãy đảm bảo bạn đã cập nhật Controller.");
                }
            });
        }

        // Sự kiện nút cộng
        $('.btn-plus-qty').click(function() {
            const $row = $(this).closest('.checkout-item');
            const id = $row.data('product-id');
            const currentQty = parseInt($row.find('.qty-input').val());
            updateCartQuantity(id, currentQty + 1, $row);
        });

        // Sự kiện nút trừ
        $('.btn-minus-qty').click(function() {
            const $row = $(this).closest('.checkout-item');
            const id = $row.data('product-id');
            const currentQty = parseInt($row.find('.qty-input').val());
            if (currentQty > 1) {
                updateCartQuantity(id, currentQty - 1, $row);
            }
        });

        // --- XỬ LÝ PHƯƠNG THỨC THANH TOÁN ---
        $('input[name="paymentMethod"]').change(function () {
            const method = $(this).val();
            const btn = $('#btnSubmit');
            $('.error-msg').hide();

            if (method === 'COD') {
                btn.prop('disabled', false).html('<i class="bi bi-bag-check-fill me-2"></i> XÁC NHẬN ĐẶT MUA');
            } else {
                btn.prop('disabled', true).text('PHƯƠNG THỨC CHƯA HỖ TRỢ');
                if (method === 'BANK') $('#msg-bank').show();
                if (method === 'MOMO') $('#msg-momo').show();
            }
        });
    });
</script>