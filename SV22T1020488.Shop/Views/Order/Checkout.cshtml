@{
    ViewBag.Title = "Thanh toán";
}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-7">
            <h4>Thông tin giao hàng</h4>
            <form action="~/Order/Init" method="post" class="mt-3">
                <div class="mb-3">
                    <label>Tỉnh thành nhận hàng:</label>
                    <select name="deliveryProvince" class="form-select" required>
                    </select>
                </div>
                <div class="mb-3">
                    <label>Địa chỉ cụ thể:</label>
                    <input type="text" name="deliveryAddress" class="form-control" placeholder="Số nhà, tên đường..." required>
                </div>
                <button type="submit" class="btn btn-success btn-lg w-100">XÁC NHẬN ĐẶT HÀNG</button>
            </form>
        </div>
        <div class="col-md-5">
            <div class="card bg-light">
                <div class="card-body">
                    <h5>Tóm tắt đơn hàng</h5>
                    <hr>
                    <p>Số lượng mặt hàng: <b>2</b></p>
                    <p>Tổng tiền thanh toán: <b class="text-danger">1.200.000 VNĐ</b></p>
                </div>
            </div>
        </div>
    </div>
</div>