@model dynamic
@{
    ViewBag.Title = "Chi tiết đơn đặt hàng";
}
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Đơn hàng #@Model.Order.OrderID</h5>
            <span class="badge bg-primary">@Model.StatusName</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6>Thông tin nhận hàng:</h6>
                    <p class="mb-1">Người nhận: <b>@Model.Order.CustomerName</b></p>
                    <p class="mb-1">Địa chỉ: @Model.Order.DeliveryAddress</p>
                    <p class="mb-1">Tỉnh thành: @Model.Order.DeliveryProvince</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h6>Ngày đặt hàng:</h6>
                    <p>@Model.Order.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <table class="table border">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">SL</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Details)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end fw-bold">@((item.Quantity * item.SalePrice).ToString("N0"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">TỔNG CỘNG:</th>
                        <th class="text-end text-danger fs-5">@Model.TotalAmount.ToString("N0") VNĐ</th>
                    </tr>
                </tfoot>
            </table>
            <a href="~/Order/History" class="btn btn-secondary mt-3">Quay lại lịch sử</a>
        </div>
    </div>
</div>