@using SV22T1020488.Shop
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - My Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin-bottom: 60px;
        }

        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.08);
        }

        .card-product {
            transition: 0.3s;
            border: none;
            border-radius: 10px;
        }

            .card-product:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,.12);
            }

        /* --- CSS CHO HIỆU ỨNG HỘP QUÀ BAY --- */
        .fly-gift-box {
            position: absolute;
            z-index: 10000;
            width: 40px;
            height: 40px;
            background-color: #ffc107;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            font-size: 20px;
            pointer-events: none;
        }

            .fly-gift-box::after {
                content: '🎁';
                font-size: 24px;
            }

        /* LƯU Ý: Dùng @@ để tránh lỗi "Expected a selector" */
        @@keyframes shake {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.4);
                color: #ffc107;
            }

            100% {
                transform: scale(1);
            }
        }

        .cart-shake {
            display: inline-block; /* Quan trọng để animation scale hoạt động */
            animation: shake 0.6s ease-in-out;
            color: #ffc107 !important;
        }
    </style>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand fw-bold" href="~/">🛍️ MY SHOP</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" href="~/Product">Sản phẩm</a></li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <a href="~/Cart" class="text-white position-relative d-inline-block text-decoration-none">
                            <i id="cart-icon" class="bi bi-cart3 fs-4"></i>
                            <span id="cart-count" class="badge rounded-pill bg-danger position-absolute top-0 start-100 translate-middle">
                                @(CartHelper.GetCart(Context).Sum(x => x.Quantity))
                            </span>
                        </a>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <div class="dropdown">
                                <a class="btn btn-light btn-sm dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    Chào, @(User.Identity?.Name ?? "Thành viên")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><a class="dropdown-item" href="~/Account/Profile"><i class="bi bi-person me-2"></i>Cá nhân</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="~/Account/Logout">Đăng xuất</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="btn-group">
                                <a href="~/Account/Login" class="btn btn-outline-light btn-sm">Đăng nhập</a>
                                <a href="~/Account/Register" class="btn btn-light btn-sm">Đăng ký</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4" style="min-height: 80vh;">
        @RenderBody()
    </main>

    <footer class="bg-white border-top py-4 mt-auto">
        <div class="container text-center text-muted">
            <p class="mb-0">&copy; 2026 - SV22T1020488 Shop</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function doFlyToCart(originElement) {
            const cart = $('#cart-icon');
            const imgToFly = $(originElement);

            if (imgToFly.length > 0 && cart.length > 0) {
                const startPos = imgToFly.offset();
                const endPos = cart.offset();

                const flyer = $('<div class="fly-gift-box"></div>');
                flyer.css({
                    'top': startPos.top + (imgToFly.height() / 2) - 20,
                    'left': startPos.left + (imgToFly.width() / 2) - 20,
                    'opacity': 1
                });

                $('body').append(flyer);

                flyer.animate({
                    'top': endPos.top,
                    'left': endPos.left,
                    'width': 10,
                    'height': 10,
                    'opacity': 0.4
                }, 800, function() {
                    flyer.remove();
                    cart.addClass('cart-shake');
                    setTimeout(() => {
                        cart.removeClass('cart-shake');
                    }, 600);
                });
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>