<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bách Hóa Tổng Hợp</title>  
    <link rel="icon" type="image/png" href="https://cdn-icons-png.flaticon.com/512/679/679821.png">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --neo-border: #1a1a1a;
            --neo-shadow: #000000;
            --neo-yellow: #f4d03f;
            --neo-pink: #f8bbd0;
            --neo-blue: #a6c1ee;
            --neo-bg: #fbc2eb;
            --neo-green: #2ecc71;
        }

        body {
            background-color: var(--neo-bg);
            background-image: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%);
            font-family: 'Space Mono', monospace;
            color: var(--neo-border);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- NEO NAVBAR STYLE --- */
        .neo-nav {
            background: white;
            border-bottom: 6px solid var(--neo-border);
            padding: 15px 0;
            margin-bottom: 20px;
        }

        .nav-brand-box {
            background: var(--neo-yellow);
            border: 4px solid var(--neo-border);
            padding: 5px 15px;
            box-shadow: 4px 4px 0px var(--neo-shadow);
            font-weight: 700;
            color: var(--neo-border);
        }

        .nav-icon-btn {
            background: white;
            border: 3px solid var(--neo-border);
            box-shadow: 4px 4px 0px var(--neo-shadow);
            padding: 5px 12px;
            position: relative;
            transition: all 0.2s;
            color: var(--neo-border);
            display: inline-block;
        }

            .nav-icon-btn:hover {
                transform: translate(-2px, -2px);
                box-shadow: 6px 6px 0px var(--neo-shadow);
                background: var(--neo-pink);
            }

        .user-avatar {
            width: 35px;
            height: 35px;
            border: 2px solid var(--neo-border);
            object-fit: cover;
        }

        .cart-badge {
            position: absolute;
            top: -10px;
            right: -10px;
            background: var(--neo-green);
            border: 2px solid var(--neo-border);
            color: var(--neo-border);
            font-weight: bold;
            padding: 2px 6px;
            font-size: 11px;
        }

        footer {
            background: var(--neo-border);
            color: white;
            border-top: 5px solid var(--neo-shadow);
        }

        .dropdown-menu {
            border: 4px solid var(--neo-border);
            box-shadow: 8px 8px 0px var(--neo-shadow);
            border-radius: 0;
        }
    </style>
</head>
<body>

    @await Html.PartialAsync("_Header")

    <main class="container px-4 flex-grow-1">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>