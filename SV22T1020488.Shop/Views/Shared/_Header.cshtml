@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor
@using SV22T1020488.Shop.Models

@{
    // --- LOGIC XỬ LÝ DỮ LIỆU NGƯỜI DÙNG ---

    // 1. Ưu tiên lấy CustomerID từ Session
    var customerId = HttpContextAccessor.HttpContext.Session.GetString("CustomerID");
    var customerName = HttpContextAccessor.HttpContext.Session.GetString("CustomerName");
    var avatar = HttpContextAccessor.HttpContext.Session.GetString("CustomerAvatar");

    // 2. CƠ CHẾ ĐỒNG BỘ TỨ THÌ: Nếu vừa đăng nhập (Cookie có) nhưng Session chưa kịp nạp (ở trang Home)
    if (User.Identity.IsAuthenticated)
    {
        // Lấy ID từ Claims nếu Session đang trống
        if (string.IsNullOrEmpty(customerId))
        {
            customerId = User.FindFirst("UserId")?.Value;
            customerName = User.FindFirst(ClaimTypes.Name)?.Value;
        }

        // Đảm bảo luôn có avatar mặc định nếu không tìm thấy
        if (string.IsNullOrEmpty(avatar))
        {
            avatar = "default.png";
        }
    }

    // 3. LOGIC GIỎ HÀNG: Luôn tính toán dựa trên danh sách thực tế
    var cartCount = 0;
    try
    {
        // Lấy danh sách giỏ hàng từ CartHelper (Hàm này phải dựa trên CustomerID bên trong logic của nó)
        var cart = CartHelper.GetCart(Context);
        if (cart != null)
        {
         
            cartCount = cart.Count();
        }
    }
    catch
    {
        cartCount = 0;
    }
}

<style>
    /* CSS Neo-Brutalism (Giữ nguyên giao diện của bạn) */
    .sticky-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: var(--neo-bg);
        padding: 15px 0;
        border-bottom: 6px solid var(--neo-border);
        transition: all 0.3s;
    }

    .brand-logo {
        font-weight: 900;
        font-size: 1.5rem;
        letter-spacing: -1px;
        color: var(--neo-border);
        text-decoration: none;
        background: var(--neo-yellow);
        border: 4px solid var(--neo-border);
        padding: 5px 15px;
        box-shadow: 4px 4px 0px var(--neo-shadow);
        display: inline-block;
    }

        .brand-logo:hover {
            color: var(--neo-border);
            transform: translate(-1px, -1px);
            box-shadow: 5px 5px 0px var(--neo-shadow);
        }

    .nav-icon-btn {
        background: white;
        border: 4px solid var(--neo-border);
        padding: 8px 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--neo-border);
        box-shadow: 4px 4px 0px var(--neo-border);
        text-decoration: none;
        position: relative;
        transition: 0.1s;
    }

        .nav-icon-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--neo-border);
            background: var(--neo-pink);
            color: var(--neo-border);
        }

    .cart-badge {
        position: absolute;
        top: -10px;
        right: -10px;
        background: #ff4444;
        color: white;
        border: 3px solid var(--neo-border);
        font-size: 0.75rem;
        font-weight: 900;
        padding: 1px 7px;
    }

    .user-avatar-nav {
        width: 32px;
        height: 32px;
        border: 2px solid var(--neo-border);
        object-fit: cover;
        background: #eee;
    }

    .btn-auth-nav {
        border: 4px solid var(--neo-border);
        padding: 8px 20px;
        font-weight: 900;
        text-decoration: none;
        color: var(--neo-border);
        box-shadow: 4px 4px 0px var(--neo-border);
        text-transform: uppercase;
        transition: 0.1s;
    }

        .btn-auth-nav:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--neo-border);
            color: var(--neo-border);
        }

    .dropdown-menu-neo {
        border: 4px solid var(--neo-border) !important;
        border-radius: 0 !important;
        box-shadow: 8px 8px 0px var(--neo-border) !important;
        padding: 0;
    }

    .dropdown-item-neo {
        padding: 12px 20px;
        font-weight: 700;
        text-transform: uppercase;
        border-bottom: 2px solid var(--neo-border);
    }

        .dropdown-item-neo:last-child {
            border-bottom: none;
        }

        .dropdown-item-neo:hover {
            background: var(--neo-yellow);
        }
</style>

<header class="sticky-header" id="navbarSticky">
    <div class="container">
        <nav class="d-flex justify-content-between align-items-center">
            @* LOGO *@
            <a href="~/" class="brand-logo">BÁCH HÓA TỔNG HỢP</a>

            <div class="d-flex gap-3 align-items-center">
                @* GIỎ HÀNG *@
                <a href="~/Cart" class="nav-icon-btn" title="Giỏ hàng">
                    <i class="bi bi-cart-dash-fill fs-4"></i>
                    @if (cartCount > 0)
                    {
                        <span class="cart-badge">@cartCount</span>
                    }
                </a>

                @* AUTHENTICATION *@
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="dropdown">
                        <a href="#" class="nav-icon-btn dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="~/images/customers/@avatar"
                                 onerror="this.src='https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava3.webp'"
                                 class="user-avatar-nav rounded-circle">
                            <span class="fw-bold d-none d-md-inline text-uppercase">@customerName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-neo mt-3">
                            <li><a class="dropdown-item dropdown-item-neo" href="~/Account/Profile"><i class="bi bi-person-badge me-2"></i>Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item dropdown-item-neo" href="~/Order/History"><i class="bi bi-box-seam me-2"></i>Đơn hàng của tôi</a></li>
                            <li><a class="dropdown-item dropdown-item-neo text-danger" href="~/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-2">
                        <a href="~/Account/Login" class="btn-auth-nav" style="background: var(--neo-yellow);">ĐĂNG NHẬP</a>
                        <a href="~/Account/Register" class="btn-auth-nav d-none d-md-block" style="background: var(--neo-pink);">ĐĂNG KÝ</a>
                    </div>
                }
            </div>
        </nav>
    </div>
</header>

<script>
    window.onscroll = function() {
        var header = document.getElementById("navbarSticky");
        if (window.pageYOffset > 50) {
            header.style.padding = "8px 0";
            header.style.backgroundColor = "#ffffff";
        } else {
            header.style.padding = "15px 0";
            header.style.backgroundColor = "var(--neo-bg)";
        }
    };
</script>