@{
    ViewData["Title"] = "Chính sách bảo mật";
}
<div class="container mt-5">
    <h1>@ViewData["Title"]</h1>
    <div class="card p-4 mt-3 shadow-sm">
        <p>Chúng tôi cam kết bảo mật tuyệt đối thông tin khách hàng.</p>
        <ul>
            <li>Thông tin cá nhân chỉ dùng cho việc giao nhận hàng.</li>
            <li>Thông tin thanh toán được xử lý qua cổng bảo mật.</li>
            <li>Chúng tôi không cung cấp dữ liệu cho bên thứ ba.</li>
        </ul>
    </div>
</div>