@{
    ViewData["Title"] = "CHÍNH SÁCH BẢO MẬT";
}

<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --neo-border: #1a1a1a;
        --neo-shadow: #000000;
        --neo-yellow: #f4d03f;
        --neo-pink: #ffafcc;
        --neo-blue: #8ecae6;
        --neo-cyan: #219ebc;
        --neo-bg: #e0f2fe;
    }

    body {
        background-color: #8ecae6;
        background-image: linear-gradient(135deg, #8ecae6 0%, #ffafcc 100%);
        font-family: 'Space Mono', monospace;
        color: var(--neo-border);
        min-height: 100vh;
        padding: 40px 15px;
    }

    .policy-wrapper {
        background: var(--neo-bg);
        border: 8px solid var(--neo-border);
        padding: 50px;
        box-shadow: 20px 20px 0px var(--neo-shadow);
        max-width: 1000px;
        margin: 0 auto;
    }

    .policy-header {
        border-bottom: 8px solid var(--neo-border);
        margin-bottom: 40px;
        padding-bottom: 20px;
    }

    .policy-title {
        font-weight: 900;
        font-size: 3rem;
        text-transform: uppercase;
        margin: 0;
        line-height: 1;
    }

    .promo-badge {
        background: var(--neo-yellow);
        border: 4px solid var(--neo-border);
        display: inline-block;
        padding: 5px 15px;
        font-weight: 900;
        margin-bottom: 15px;
        box-shadow: 4px 4px 0px var(--neo-border);
    }

    .policy-card {
        background: white;
        border: 6px solid var(--neo-border);
        padding: 30px;
        box-shadow: 12px 12px 0px var(--neo-border);
        margin-bottom: 40px;
    }

        .policy-card p {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 25px;
        }

    .policy-list {
        list-style: none;
        padding: 0;
    }

        .policy-list li {
            background: var(--neo-pink);
            border: 4px solid var(--neo-border);
            margin-bottom: 15px;
            padding: 15px 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            box-shadow: 6px 6px 0px var(--neo-shadow);
            transition: 0.2s;
        }

            .policy-list li:hover {
                transform: translate(-3px, -3px);
                box-shadow: 9px 9px 0px var(--neo-shadow);
            }

            .policy-list li i {
                font-size: 1.5rem;
                margin-right: 15px;
                color: var(--neo-border);
            }

    .btn-back {
        display: inline-block;
        background: var(--neo-cyan);
        color: white;
        text-decoration: none;
        padding: 15px 30px;
        font-weight: 900;
        border: 4px solid var(--neo-border);
        box-shadow: 6px 6px 0px var(--neo-shadow);
        text-transform: uppercase;
        margin-top: 20px;
    }

        .btn-back:hover {
            color: white;
            transform: translate(-3px, -3px);
            box-shadow: 9px 9px 0px var(--neo-shadow);
        }

    @@media (max-width: 768px) {
        .policy-wrapper {
            padding: 25px;
        }

        .policy-title {
            font-size: 1.8rem;
        }
    }
</style>

<div class="policy-wrapper">
    <div class="policy-header">
        <div class="promo-badge">SECURITY FIRST</div>
        <h1 class="policy-title">@ViewData["Title"]</h1>
    </div>

    <div class="policy-card">
        <p><i class="bi bi-shield-lock-fill me-2"></i> Chúng tôi cam kết bảo mật tuyệt đối thông tin khách hàng.</p>

        <ul class="policy-list">
            <li>
                <i class="bi bi-truck"></i>
                Thông tin cá nhân chỉ dùng cho việc giao nhận hàng.
            </li>
            <li>
                <i class="bi bi-credit-card-2-front"></i>
                Thông tin thanh toán được xử lý qua cổng bảo mật.
            </li>
            <li>
                <i class="bi bi-people-fill"></i>
                Chúng tôi không cung cấp dữ liệu cho bên thứ ba.
            </li>
        </ul>
    </div>

    <a href="/" class="btn-back">
        <i class="bi bi-arrow-left"></i> QUAY LẠI CỬA HÀNG
    </a>
</div>