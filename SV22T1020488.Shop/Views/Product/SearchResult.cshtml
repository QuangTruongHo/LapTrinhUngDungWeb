@using SV22T1020488.Models.Common
@using SV22T1020488.Models.Catalog
@model PagedResult<Product>
@{
    Layout = null;
    // Cập nhật đường dẫn ảnh mặc định nội bộ
    string defaultImg = Url.Content("~/images/products/demo.png");
}

@if (Model.DataItems != null && Model.DataItems.Any())
{
    @* --- DANH SÁCH SẢN PHẨM --- *@
    <div class="row g-4">
        @foreach (var item in Model.DataItems)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 product-item">
                <div class="card neo-card h-100"
                     style="border: 4px solid #1a1a1a; box-shadow: 8px 8px 0px #000; border-radius: 0; transition: 0.2s; background: #fff; cursor: pointer;"
                     onclick="if(!$(event.target).closest('button, input, a').length) window.location.href='@Url.Content("~/Product/Detail/" + item.ProductID)'">

                    @* KHU VỰC ẢNH *@
                    <div class="product-img-container" style="height: 200px; overflow: hidden; border-bottom: 4px solid #1a1a1a; background: #fff; display: flex; align-items: center; justify-content: center; position: relative;">
                        @{
                            // Ưu tiên ảnh từ database, nếu không có thì lấy ảnh demo
                            var photoUrl = string.IsNullOrEmpty(item.Photo)
                            ? defaultImg
                            : Url.Content("~/images/products/" + item.Photo);
                        }
                        <img src="@photoUrl"
                             class="product-img"
                             alt="@item.ProductName"
                             style="max-height: 100%; max-width: 100%; object-fit: contain; padding: 10px;"
                             onerror="this.onerror=null; this.src='@defaultImg';">
                    </div>

                    <div class="card-body d-flex flex-column p-3">
                        <h6 class="card-title fw-bold text-uppercase text-truncate" title="@item.ProductName">@item.ProductName</h6>
                        <p class="text-muted small mb-1">Đơn vị: @item.Unit</p>
                        <p class="fw-bold fs-5 mb-3" style="color: #1a1a1a;">@item.Price.ToString("N0") <small>đ</small></p>

                        <div class="mt-auto">
                            @* DÒNG 1: BỘ CHỌN SỐ LƯỢNG VÀ NÚT THÊM VÀO GIỎ *@
                            <div class="d-flex gap-2 mb-2">
                                <div class="d-flex flex-grow-1" style="border: 3px solid #1a1a1a; box-shadow: 3px 3px 0px #1a1a1a;">
                                    <button type="button" class="btn-qty-minus"
                                            style="background: #eee; border: none; border-right: 3px solid #1a1a1a; width: 30px; font-weight: 900;">
                                        -
                                    </button>
                                    <input type="number" class="input-quantity-val text-center" value="1" min="1"
                                           style="width: 100%; border: none; outline: none; font-weight: 900; background: #fff;">
                                    <button type="button" class="btn-qty-plus"
                                            style="background: #eee; border: none; border-left: 3px solid #1a1a1a; width: 30px; font-weight: 900;">
                                        +
                                    </button>
                                </div>

                                <button type="button" class="btn-add-to-cart" data-id="@item.ProductID"
                                        style="background: #fff; border: 3px solid #1a1a1a; font-weight: 900; width: 45px; box-shadow: 3px 3px 0px #1a1a1a; cursor: pointer;">
                                    <i class="bi bi-cart-plus-fill"></i>
                                </button>
                            </div>

                            @* DÒNG 2: NÚT MUA NGAY *@
                            <a href="@Url.Content("~/Cart/BuyNow/" + item.ProductID)"
                               class="btn-buy-now w-100 d-block text-center text-decoration-none"
                               style="background: #f4d03f; border: 3px solid #1a1a1a; font-weight: 900; padding: 10px; box-shadow: 4px 4px 0px #1a1a1a; color: #1a1a1a; text-transform: uppercase;">
                                <i class="bi bi-lightning-charge-fill me-1"></i> Mua ngay
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* --- PHÂN TRANG --- *@
    @if (Model.PageCount > 1)
    {
        <div class="d-flex justify-content-center align-items-center mt-5 mb-5 pb-5 flex-wrap gap-2">
            @if (Model.HasPreviousPage)
            {
                <button onclick="doSearch(@(Model.Page - 1))" class="btn btn-outline-dark rounded-0 fw-bold border-3 px-3 shadow-sm">
                    <i class="bi bi-chevron-left"></i>
                </button>
            }

            @foreach (var pageItem in Model.GetDisplayPages(2))
            {
                if (pageItem.Page == 0)
                {
                    <span class="fw-bold px-2">...</span>
                }
                else
                {
                    <button onclick="doSearch(@pageItem.Page)"
                            class="btn @(pageItem.IsCurrent ? "btn-dark" : "btn-outline-dark") rounded-0 fw-bold border-3 px-3 shadow-sm"
                            style="@(pageItem.IsCurrent ? "box-shadow: 4px 4px 0px #f4d03f;" : "")">
                        @pageItem.Page
                    </button>
                }
            }

            @if (Model.HasNextPage)
            {
                <button onclick="doSearch(@(Model.Page + 1))" class="btn btn-outline-dark rounded-0 fw-bold border-3 px-3 shadow-sm">
                    <i class="bi bi-chevron-right"></i>
                </button>
            }
        </div>
    }
}
else
{
    <div class="text-center p-5 border-5 border-dark bg-white" style="box-shadow: 10px 10px 0px #000;">
        <h3 class="fw-bold text-uppercase">Không tìm thấy sản phẩm nào!</h3>
        <p>Thử tìm kiếm với từ khóa khác xem sao bạn nhé.</p>
    </div>
}

<style>
    .neo-card {
        border: 4px solid #1a1a1a !important;
        box-shadow: 8px 8px 0px #000 !important;
        border-radius: 0 !important;
        background: #fff;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
    }

        .neo-card:hover {
            transform: translate(-4px, -4px);
            box-shadow: 12px 12px 0px #000 !important;
        }

    .product-img-container {
        height: 200px;
        overflow: hidden;
        border-bottom: 4px solid #1a1a1a;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-img {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
        padding: 10px;
        transition: transform 0.3s ease;
    }

    .neo-card:hover .product-img {
        transform: scale(1.08);
    }

    .btn-qty-minus, .btn-qty-plus {
        background: #eee;
        border: none;
        width: 30px;
        font-weight: 900;
        transition: all 0.2s;
    }

        .btn-qty-minus:hover, .btn-qty-plus:hover {
            background: #f4d03f !important;
        }

    .btn-add-to-cart:hover {
        transform: translate(-2px, -2px);
        box-shadow: 5px 5px 0px #1a1a1a;
        background: #f8bbd0 !important;
    }

    .btn-buy-now:hover {
        transform: translate(-3px, -3px);
        box-shadow: 7px 7px 0px #1a1a1a;
        filter: brightness(1.05);
    }

    .fly-gift-box {
        position: absolute;
        width: 50px;
        height: 50px;
        background-color: #f8bbd0;
        border: 3px solid #1a1a1a;
        box-shadow: 4px 4px 0px #000;
        z-index: 99999;
        pointer-events: none;
        transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .fly-gift-box::after {
            content: '\F3F4';
            font-family: 'bootstrap-icons' !important;
            font-size: 1.5rem;
            color: #1a1a1a;
        }

        .fly-gift-box.shrinking {
            width: 15px;
            height: 15px;
            opacity: 0.3;
            transform: scale(0.2);
        }

    .cart-shake {
        animation: neo-shake 0.5s ease-in-out;
    }

    @@keyframes neo-shake {
        0% {
            transform: scale(1.2) rotate(0deg);
        }

        25% {
            transform: scale(1.2) rotate(15deg);
        }

        50% {
            transform: scale(1.2) rotate(-15deg);
        }

        75% {
            transform: scale(1.2) rotate(10deg);
        }

        100% {
            transform: scale(1) rotate(0deg);
        }
    }
</style>

<script>
    $(document).ready(function () {
        // Ngăn sự kiện click Card khi nhấn vào input/nút/link
        $(document).off('click', '.neo-card button, .neo-card input, .neo-card a').on('click', '.neo-card button, .neo-card input, .neo-card a', function(e) {
            e.stopPropagation();
        });

        // Xử lý nút tăng giảm số lượng
        $(document).off('click', '.btn-qty-plus').on('click', '.btn-qty-plus', function() {
            var input = $(this).siblings('.input-quantity-val');
            input.val(parseInt(input.val()) + 1);
        });

        $(document).off('click', '.btn-qty-minus').on('click', '.btn-qty-minus', function() {
            var input = $(this).siblings('.input-quantity-val');
            var val = parseInt(input.val());
            if (val > 1) input.val(val - 1);
        });

        // Ajax thêm vào giỏ hàng
        $(document).off('click', '.btn-add-to-cart').on('click', '.btn-add-to-cart', function (e) {
            var $button = $(this);
            var productId = $button.data('id');
            var $productItem = $button.closest('.product-item');
            var quantity = $productItem.find('.input-quantity-val').val();
            var $productImg = $productItem.find('.product-img');
            var $cartIcon = $('.nav-icon-btn');

            $.ajax({
                url: '@Url.Content("~/Cart/AddToCartAjax")',
                type: 'POST',
                data: { id: productId, quantity: quantity },
                success: function (response) {
                    if (response.success) {
                        if ($cartIcon.length > 0 && $productImg.length > 0) {
                            var cartOffset = $cartIcon.offset();
                            var imgOffset = $productImg.offset();
                            var $giftBox = $('<div class="fly-gift-box"></div>');
                            $giftBox.css({
                                left: (imgOffset.left + $productImg.width() / 2) + 'px',
                                top: (imgOffset.top + $productImg.height() / 2) + 'px',
                                transform: 'translate(-50%, -50%)'
                            });
                            $('body').append($giftBox);
                            setTimeout(function () {
                                $giftBox.css({
                                    left: (cartOffset.left + $cartIcon.width() / 2) + 'px',
                                    top: (cartOffset.top + $cartIcon.height() / 2) + 'px'
                                }).addClass('shrinking');
                            }, 50);
                            setTimeout(function () {
                                $giftBox.remove();
                                $('.cart-badge').text(response.totalItems).hide().fadeIn();
                                $cartIcon.addClass('cart-shake');
                                setTimeout(function(){ $cartIcon.removeClass('cart-shake'); }, 500);
                            }, 800);
                        }
                    } else { alert(response.message || 'Lỗi khi thêm vào giỏ.'); }
                }
            });
        });
    });
</script>