@model SV22T1020488.Models.Catalog.ProductPhoto
@{
    // Cố định tiêu đề là Chỉnh sửa vì file này chỉ dùng để Edit
    ViewBag.Title = "Thay đổi ảnh mặt hàng";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thay đổi
    </button>

    @* Quay lại đúng tab ảnh của sản phẩm *@
    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Hủy bỏ
    </a>
}

<div class="row justify-content-center mt-3">
    <div class="col-md-8">
        <div class="card card-outline card-success shadow-sm">
            <div class="card-header">
                <h5 class="mb-0 fw-bold text-success">
                    <i class="bi bi-pencil-square me-2"></i>@ViewBag.Title
                </h5>
            </div>

            <div class="card-body p-4">
                <form id="formEdit" action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
                    @* Các trường ẩn cực kỳ quan trọng để biết đang sửa ảnh nào *@
                    <input type="hidden" asp-for="PhotoID" />
                    <input type="hidden" asp-for="ProductID" />

                    @* Giữ tên file ảnh cũ nếu người dùng không chọn file mới *@
                    <input type="hidden" asp-for="Photo" id="PhotoData" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Vui lòng kiểm tra lại dữ liệu.
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Thay đổi ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   id="filePicker"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImage(this)" />
                            <div class="form-text italic small mt-1 text-muted">Bỏ trống nếu muốn giữ nguyên ảnh cũ</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Ảnh hiện tại</label>
                        <div class="col-sm-9">
                            @{
                                string photoSrc = string.IsNullOrEmpty(Model.Photo)
                                ? Url.Content("~/images/products/nophoto.png")
                                : Url.Content($"~/images/products/{Model.Photo}");
                            }
                            <img id="imgPreview"
                                 src="@photoSrc"
                                 class="img-thumbnail shadow-sm"
                                 style="max-height:300px; min-width:150px; object-fit:contain; border: 2px solid #198754;"
                                 onerror="this.src='@Url.Content("~/images/products/nophoto.png")'" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold" asp-for="Description">Mô tả ảnh</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="Description"
                                   class="form-control"
                                   placeholder="Nhập mô tả ảnh..." />
                            <span asp-validation-for="Description" class="text-danger small italic"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold" asp-for="DisplayOrder">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   asp-for="DisplayOrder"
                                   class="form-control"
                                   min="1" />
                            <span asp-validation-for="DisplayOrder" class="text-danger small italic"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input"
                                       type="checkbox"
                                       asp-for="IsHidden"
                                       id="IsHidden" />
                                <label class="form-check-label text-dark fw-medium" for="IsHidden">
                                    Tạm ẩn ảnh này
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="card-footer bg-light text-center py-2">
                <small class="text-muted">
                    Đang chỉnh sửa ảnh mã số: <strong>#@Model.PhotoID</strong>
                    | Tên file: <strong>@(string.IsNullOrEmpty(Model.Photo) ? "Chưa có file" : Model.Photo)</strong>
                </small>
            </div>
        </div>
    </div>
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('imgPreview').style.border = "2px dashed #0dcaf0";
                document.getElementById('imgPreview').src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);

            // Xóa giá trị cũ để server biết có ảnh mới được upload lên
            document.getElementById('PhotoData').value = "";
        }
    }
</script>

<style>
    .italic {
        font-style: italic;
    }

    .card-outline.card-success {
        border-top: 3px solid #198754;
    }

    .img-thumbnail {
        transition: all .3s ease;
        background-color: #fff;
    }

        .img-thumbnail:hover {
            transform: scale(1.02);
        }

    .text-danger.small.italic {
        display: block;
        margin-top: 5px;
    }
</style>