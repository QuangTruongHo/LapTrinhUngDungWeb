@model SV22T1020488.Models.Catalog.Product
@using SV22T1020488.BusinessLayers
@{
    ViewBag.Title = Model.ProductID == 0 ? "Thêm mới mặt hàng" : "Cập nhật mặt hàng";
    ViewBag.ProductID = Model.ProductID;
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i> Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/SaveData" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="Photo" id="PhotoData" />

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Tên mặt hàng</label>
                        <div class="col-sm-10">
                            <input type="text" asp-for="ProductName" class="form-control" placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Loại hàng</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="CategoryID"
                                    asp-items="@(await SV22T1020488.Admin.SelectListHelper.Categories())">
                                <option value="0">-- Chọn loại hàng --</option>
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end fw-bold">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="SupplierID"
                                    asp-items="@(await SV22T1020488.Admin.SelectListHelper.Suppliers())">
                                <option value="0">-- Chọn nhà cung cấp --</option>
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Đơn vị tính</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for="Unit" class="form-control" placeholder="cái, hộp, kg..." />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end fw-bold">Giá bán</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for="Price" class="form-control money-input text-end"
                                   value="@Model.Price.ToString("N0")" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Mô tả</label>
                        <div class="col-sm-10">
                            <textarea asp-for="ProductDescription" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Ảnh sản phẩm</label>
                        <div class="col-sm-10">
                            <input type="file" id="filePicker" name="uploadPhoto" class="form-control" accept="image/*" onchange="previewImage()" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="@(string.IsNullOrEmpty(Model.Photo) ? Url.Content("~/images/products/nophoto.png") : (Model.Photo.StartsWith("data:") ? Model.Photo : Url.Content($"~/images/products/{Model.Photo}")))"
                                     class="img-thumbnail"
                                     style="max-height: 200px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsSelling" id="IsWorking" />
                                <label class="form-check-label fw-bold" for="IsWorking">Mặt hàng này hiện đang được rao bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    <div class="container-fluid p-0">
        <div id="photo-container" class="mt-4">
            @await Html.PartialAsync("ListPhotos", await CatalogDataService.ListPhotosAsync(Model.ProductID))
        </div>

        <div id="attribute-container" class="mt-4">
            @await Html.PartialAsync("ListAttributes", await CatalogDataService.ListAttributesAsync(Model.ProductID))
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Kiểm tra xem jQuery đã chạy chưa
            console.log("jQuery version:", $.fn.jquery);

            // Xử lý sự kiện click nút xóa (Dùng Delegation để bắt được các nút trong PartialView)
            $(document).on('click', '.btn-delete-confirm', function (e) {
                e.preventDefault();

                var link = $(this).attr('href');
                var message = $(this).data('message') || "Dữ liệu này sẽ bị xóa vĩnh viễn!";

                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: message,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý xóa',
                    cancelButtonText: 'Hủy bỏ',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = link;
                    }
                });
            });
        });

        // Hàm xem trước ảnh khi chọn file
        function previewImage() {
            var filePicker = document.getElementById('filePicker');
            var file = filePicker.files[0];
            if (file) {
                var previewUrl = window.URL.createObjectURL(file);
                document.getElementById('imgPreview').src = previewUrl;
                if(document.getElementById('PhotoData')) {
                    document.getElementById('PhotoData').value = "";
                }
            }
        }
    </script>
}