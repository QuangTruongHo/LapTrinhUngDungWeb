@using SV22T1020488.Models.Sales
@model IEnumerable<SV22T1020488.Models.Sales.OrderViewInfo>
@{
    ViewBag.Title = "Bảng điều khiển";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hôm nay</h6>
                        <h3 class="mb-0">@string.Format("{0:N0}", ViewBag.TotalRevenue ?? 0) đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng mới</h6>
                        <h3 class="mb-0">@ViewBag.PendingOrders</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@ViewBag.TotalCustomers</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">@ViewBag.TotalProducts</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-8">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="card-title mb-0">Xu hướng doanh thu (7 ngày gần nhất)</h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" style="min-height: 250px; height: 250px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-outline card-danger">
            <div class="card-header">
                <h5 class="card-title mb-0">Tỷ lệ trạng thái đơn</h5>
            </div>
            <div class="card-body">
                <canvas id="orderStatusChart" style="min-height: 250px; height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng mới nhất
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Ngày đặt</th>
                                <th class="text-center">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    string badgeClass = item.Status switch
                                    {
                                        OrderStatusEnum.New => "bg-primary",
                                        OrderStatusEnum.Accepted => "bg-info",
                                        OrderStatusEnum.Shipping => "bg-warning text-dark",
                                        OrderStatusEnum.Completed => "bg-success",
                                        OrderStatusEnum.Cancelled => "bg-secondary",
                                        OrderStatusEnum.Rejected => "bg-danger",
                                        _ => "bg-dark"
                                    };

                                    <tr>
                                        <td class="align-middle">#@item.OrderID</td>
                                        <td class="align-middle">
                                            <b>@item.CustomerName</b>
                                        </td>
                                        <td class="align-middle">@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-center align-middle">
                                            <span class="badge @badgeClass">
                                                @item.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center p-3 text-muted">Không có đơn hàng mới</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Sử dụng sự kiện window.onload để chắc chắn Chart.js và DOM đã sẵn sàng
    window.onload = function () {
        // Biểu đồ doanh thu
        const revCanvas = document.getElementById('revenueChart');
        if (revCanvas) {
            new Chart(revCanvas, {
                type: 'line',
                data: {
                    labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: [1200000, 1900000, 3000000, 500000, 2400000, 3500000, 4000000],
                        borderColor: '#007bff',
                        backgroundColor: 'rgba(0, 123, 255, 0.1)',
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }

        // Biểu đồ trạng thái đơn
        const sttCanvas = document.getElementById('orderStatusChart');
        if (sttCanvas) {
            new Chart(sttCanvas, {
                type: 'doughnut',
                data: {
                    labels: ['Đơn mới', 'Hoàn tất', 'Khác'],
                    datasets: [{
                        data: [@(ViewBag.PendingOrders ?? 0), 15, 5],
                        backgroundColor: ['#007bff', '#28a745', '#6c757d']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }
    };
</script>