@model SV22T1020488.Models.Partner.Customer
@{
    ViewBag.Title = "Mật khẩu khách hàng";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i> Đổi mật khẩu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @* 1. THÔNG BÁO THẤT BẠI (Dùng ModelState) *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show border-start border-4 border-danger" role="alert">
                <div class="fw-bold text-uppercase mb-1">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Lỗi thực hiện
                </div>
                @Html.ValidationSummary(false, "")
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @* 2. THÔNG BÁO THÀNH CÔNG (Dùng TempData) *@
        @if (TempData["PasswordSuccess"] != null)
        {
            <div id="success-alert" class="alert alert-success alert-dismissible fade show fw-bold border-start border-4 border-success" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                @TempData["PasswordSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card card-warning card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 fw-bold"><i class="bi bi-shield-lock me-2"></i> QUẢN LÝ MẬT KHẨU</h5>
            </div>
            <div class="card-body">
                <form id="formChangePassword" action="~/Customer/ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.CustomerID" />

                    @* ... phần thông tin khách hàng giữ nguyên ... *@
                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3 fw-bold text-uppercase"><i class="bi bi-info-circle me-1"></i> Đối tượng áp dụng</legend>
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Khách hàng:</dt>
                            <dd class="col-sm-9">@Model.CustomerName</dd>
                            <dt class="col-sm-3">Email đăng nhập:</dt>
                            <dd class="col-sm-9 text-primary">@Model.Email</dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3 fw-bold text-uppercase"><i class="bi bi-lock me-1"></i> Nhập mật khẩu</legend>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input type="password" name="newPassword" class="form-control" placeholder="Nhập mật khẩu mới" required autofocus />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Xác nhận lại mật khẩu</label>
                            <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu để xác nhận" required />
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Tự động ẩn thông báo thành công sau 3 giây
            if ($("#success-alert").length > 0) {
                setTimeout(function () {
                    $("#success-alert").fadeOut("slow");
                }, 3000);
            }
        });
    </script>
}